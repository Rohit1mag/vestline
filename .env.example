# Clerk (https://dashboard.clerk.com) — prefer `.env.local` for local dev
# https://clerk.com/docs/react/getting-started/quickstart
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Supabase (Project Settings → API) — https://supabase.com/dashboard
# Prefer the legacy anon JWT (starts with eyJ…) for this app unless you migrate per Supabase docs.
# If you see PGRST301 / "No suitable key to decode the JWT": add Clerk under Supabase → Authentication
# → Third-party auth, and enable Clerk↔Supabase in both dashboards.
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
